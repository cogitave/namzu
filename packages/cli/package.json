{
	"name": "@namzu/cli",
	"version": "0.0.3",
	"description": "Operator CLI for the Namzu agent platform — namzu doctor + future commands. Dual-purpose: standalone bin (`namzu doctor`) and library (`import { runDoctor } from '@namzu/cli'`).",
	"keywords": [
		"namzu",
		"ai",
		"agent",
		"cli",
		"doctor"
	],
	"license": "MIT",
	"author": "Namzu Contributors",
	"homepage": "https://namzu.ai",
	"repository": {
		"type": "git",
		"url": "https://github.com/cogitave/namzu.git",
		"directory": "packages/cli"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"namzu": "./dist/bin.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc --build",
		"dev": "tsc --build --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"test": "vitest run"
	},
	"dependencies": {
		"@namzu/sdk": "workspace:^",
		"commander": "^14.0.3",
		"ink": "^7.0.3",
		"react": "^19.2.6",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/react": "^19.2.15",
		"typescript": "^5.5.0",
		"vitest": "^2.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
