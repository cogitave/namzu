{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "references": [
    { "path": "./packages/sdk" },
    { "path": "./packages/cli" },
    { "path": "./packages/telemetry" },
    { "path": "./packages/computer-use" },
    { "path": "./packages/providers/bedrock" },
    { "path": "./packages/providers/openrouter" },
    { "path": "./packages/providers/ollama" },
    { "path": "./packages/providers/lmstudio" },
    { "path": "./packages/providers/http" },
    { "path": "./packages/providers/openai" },
    { "path": "./packages/providers/anthropic" }
  ],
  "files": []
}
